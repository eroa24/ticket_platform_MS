# Excluir todo lo innecesario para el build context de Docker
# Reduce drásticamente el tamaño del context enviado al daemon Docker

# IDE y editor
.idea/
.vscode/
*.iml
*.ipr
*.iws

# Build outputs
**/build/
**/out/
**/target/
**/bin/

# Gradle (se descarga fresco en el builder)
.gradle/
!gradle/wrapper/

# Git
.git/
.gitignore

# Docker (evita recursión)
Dockerfile
docker-compose.yml
.dockerignore

# Docs y configs locales
*.md
*.txt
LICENSE

# OS files
.DS_Store
Thumbs.db
